{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polly subtitle translator",
  "version": "1.0.6",
  "identifier": "com.zimufan.ai-subtrans",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Polly subtitle translator",
        "width": 520,
        "height": 325,
        "minWidth": 480,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "backgroundColor": "#ffffff",
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "copyright": "Copyright 2025 terry. Licensed under Apache-2.0",
    "category": "Utility",
    "shortDescription": "AI Subtitle Translation & Editor",
    "longDescription": "AI-powered subtitle translation and editing tool with video preview",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3RUFBMUI4NjA1QjREODcKUldTSFRWdGd1S0hxdHltcFdJZlhSVjRyOUdhWXFMZE0xU1c0M1g1Mm5odDhHQzIvWlNhdlZ1akQK",
      "endpoints": [
        "https://terry2010.github.io/polly-subtitle-translator/latest.json"
      ]
    }
  }
}
