{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:write-files",
    "shell:default",
    "shell:allow-open",
    "os:default",
    "notification:default",
    "process:default",
    "updater:default"
  ]
}
